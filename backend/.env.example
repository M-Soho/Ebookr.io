# --- Core ---
NODE_ENV=development
PORT=4001
DATABASE_URL="file:./dev.db"

# Auth (change in production)
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=7d

# URLs (CORS + links in emails)
CLIENT_ORIGIN=http://localhost:5175
API_URL=http://localhost:4001

# Single-use token lifetimes (minutes)
EMAIL_VERIFY_TTL_MIN=1440
PASSWORD_RESET_TTL_MIN=60

# Email delivery (leave EMAIL_PROVIDER unset in dev -> mailer logs to console)
# EMAIL_PROVIDER=resend
EMAIL_FROM="Ebookr <no-reply@ebookr.io>"

# Stripe billing (optional — endpoints gated off until keys are set)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_TRIAL_DAYS=0
